<div class="row mt-5">
    <div class="col-8 offset-2 col-md-6 offset-md-3">
        <div class="alert alert-danger shadow-sm border-0 py-4 px-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-circle-exclamation fa-2xl me-3"></i>
                <div>
                    <h4 class="alert-heading fw-bold mb-1">Oops! Something went wrong.</h4>
                    <p class="mb-0 text-secondary">
                        <%= err.message %>
                    </p>
                </div>
            </div>
            
            <hr class="my-3">

            <div class="d-flex justify-content-between align-items-center">
                <p class="mb-0 small text-muted">Error Code: <%= err.statusCode || 500 %></p>
                <a href="/listings" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                    Return Home
                </a>
            </div>
        </div>
    </div>
</div>

