<% layout("/layouts/boilerplate") %>

<div class="row mt-4">
  <div class="col-10 offset-1">
    <h2 class="mb-4 text-dark font-weight-bold">My Reserved Bookings</h2>
    
    <% if (bookings && bookings.length > 0) { %>
      <div class="row">
        <% bookings.forEach(b => { %>
          <div class="col-md-6 col-12 mb-4">
            <div class="card shadow-sm border-0 rounded-3 overflow-hidden bg-white">
              <div class="row g-0">
                <!-- Left: Card image thumbnail -->
                <div class="col-4">
                  <img src="<%= b.listing.image.url %>" class="img-fluid h-100" style="object-fit: cover;" alt="<%= b.listing.title %>" />
                </div>
                <!-- Right: Details -->
                <div class="col-8">
                  <div class="card-body d-flex flex-column h-100 justify-content-between">
                    <div>
                      <div class="d-flex justify-content-between align-items-start">
                        <h5 class="card-title text-dark fw-bold mb-1" style="font-size: 1.1em; line-height: 1.3;"><%= b.listing.title %></h5>
                        <% if (b.status === 'Paid') { %>
                          <span class="badge bg-success">Paid</span>
                        <% } else { %>
                          <span class="badge bg-warning text-dark">Pending</span>
                        <% } %>
                      </div>
                      <p class="text-muted small mb-2"><%= b.listing.location %>, <%= b.listing.country %></p>
                      <div class="text-muted small">
                        <strong>Check-in:</strong> <%= b.checkIn.toLocaleDateString() %><br>
                        <strong>Check-out:</strong> <%= b.checkOut.toLocaleDateString() %><br>
                        <strong>Total Price:</strong> <span class="fw-bold text-dark">&#8377; <%= b.totalPrice.toLocaleString("en-IN") %></span>
                      </div>
                    </div>
                    
                    <div class="mt-3 d-flex justify-content-between align-items-center">
                      <a href="/listings/<%= b.listing._id %>" class="btn btn-sm btn-outline-primary">View Stay</a>
                      <% if (b.status === 'Pending') { %>
                        <a href="/bookings/<%= b._id %>/pay" class="btn btn-sm btn-danger" style="background-color: #fe424d; border-color: #fe424d;">Pay Now</a>
                      <% } %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-5 bg-white shadow-sm rounded-3 border">
        <h4 class="text-muted">You have no active reservations.</h4>
        <p class="text-muted">Explore and book the perfect places for your travels!</p>
        <a href="/listings" class="btn btn-danger mt-2" style="background-color: #fe424d; border-color: #fe424d; padding: 10px 20px;">Explore Listings</a>
      </div>
    <% } %>
  </div>
</div>
